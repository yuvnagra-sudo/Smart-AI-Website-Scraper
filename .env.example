# ============================================================
# Smart AI Website Scraper - Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
# MySQL connection string (required for all saves to work)
DATABASE_URL=mysql://user:password@host:3306/dbname

# --- AI Provider (choose ONE) ---
#
# OPTION A: Gemini 3 (RECOMMENDED — better output quality for agentic scraping)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
#
# Choose your Gemini 3 model (default if not set: gemini-3-flash-preview)
#
#   gemini-3-flash-preview          Best value: frontier intelligence, fast
#                                   $0.50 input / $3.00 output per 1M tokens
#
#   gemini-3.1-pro-preview          Best quality: highest accuracy, complex pages
#                                   $2.00 input / $12.00 output per 1M tokens
#
#   gemini-3.1-flash-lite-preview   Budget: simple extraction, high volume
#                                   $0.25 input / $1.50 output per 1M tokens
#
# GEMINI_MODEL=gemini-3-flash-preview
#
# OPTION B: OpenAI (used only if GEMINI_API_KEY is not set)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Jina AI (website fetching) ---
# Optional but strongly recommended — Jina API key for fast website content extraction
# Without this, falls back to Puppeteer (slower, resource-heavy)
JINA_API_KEY=jina_...

# --- Serper API (web search fallback in agent mode) ---
# Optional — used when a website has no useful content and the agent needs to search the web
# Get your key at: https://serper.dev (free tier: 2,500 queries/month)
# SERPER_API_KEY=...

# --- LLM Rate Limit ---
# Requests per minute cap sent to the LLM provider. Must match your billing tier.
# Gemini 3 Flash — Tier 1 (any paid account):  300 RPM
# Gemini 3 Flash — Tier 2 ($250+ cumulative):  2000 RPM  ← default
# If you see 429 / RESOURCE_EXHAUSTED errors, lower this value to 300.
# LLM_RPM_LIMIT=2000

# --- Authentication ---
# Password required to log in to the app
ADMIN_PASSWORD=choose-a-strong-password
# Secret used to sign session JWTs — use a long random string
JWT_SECRET=some-long-random-secret-string

# --- File Storage (AWS S3) ---
# Required for uploading Excel input files and storing result files
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# --- Vayne API (optional enrichment provider) ---
VAYNE_API_KEY=...

# --- Development ---
# Set to "true" to skip password login and use a hardcoded admin user.
# NEVER set this in production.
# DEV_BYPASS_AUTH=true
NODE_ENV=development
